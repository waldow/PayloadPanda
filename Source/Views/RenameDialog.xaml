<Window x:Class="PayloadPanda.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename"
        Width="350" Height="150"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="{DynamicResource BgDeep}"
        Foreground="{DynamicResource TextPrimary}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      CornerRadius="0" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{DynamicResource WindowBorderAccent}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource BgSurface}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="12,6">
                <TextBlock Text="Rename Request" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"/>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="16,12">
                <Label Content="Name" FontSize="12" Padding="0,0,0,4"/>
                <TextBox x:Name="NameBox" FontSize="13"
                         KeyDown="NameBox_KeyDown"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource BgSurface}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource GhostButton}"
                            Click="Cancel_Click" Margin="0,0,8,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Content="OK" Style="{StaticResource PrimaryButton}"
                            Click="OK_Click" MinWidth="60"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
