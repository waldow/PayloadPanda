<UserControl x:Class="PayloadPanda.Views.RequestWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="100"/>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*" MinHeight="100"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource BgSurface}"
                Padding="12,10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="4" Margin="0,0,8,0" Padding="2"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Background="{DynamicResource BgInput}">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Style="{StaticResource ModeTogglePill}" Content="HTTP"
                                     ToolTip="Standard request via HttpClient"
                                     IsChecked="{Binding SelectedRequestMode, Converter={StaticResource EnumMatchToBool}, ConverterParameter=Http}"/>
                        <RadioButton Style="{StaticResource ModeTogglePill}" Content="RAW"
                                     ToolTip="Low-level TCP/TLS socket - inspect DNS, handshake, certs and raw bytes"
                                     IsChecked="{Binding SelectedRequestMode, Converter={StaticResource EnumMatchToBool}, ConverterParameter=RawSocket}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="4" Margin="0,0,8,0"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Background="{DynamicResource BgInput}">
                    <ComboBox ItemsSource="{Binding AvailableMethods}"
                              SelectedItem="{Binding SelectedMethod}"
                              FontWeight="Bold" FontSize="13"
                              MinWidth="90" BorderThickness="0"
                              Foreground="{Binding SelectedMethod, Converter={StaticResource MethodToBrush}}"/>
                </Border>

                <TextBox Grid.Column="2"
                         Text="{Binding RequestUrl, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{DynamicResource CodeFont}"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SendCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Grid Grid.Column="3">
                    <Button Content="Send"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SendCommand}"
                            MinWidth="80"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                    <Button Content="Cancel"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding CancelCommand}"
                            MinWidth="80"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedRequestTabIndex}"
                    Background="Transparent">
            <TabItem Header="Params">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding QueryParams}"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="On" Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                            <DataGridTextColumn Header="Key" Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Width="*">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="{StaticResource BgInput}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="*">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="{StaticResource BgInput}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="" Width="30">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="x" Style="{StaticResource GhostButton}"
                                                FontSize="10" Padding="2"
                                                Command="{Binding DataContext.RemoveParamRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="1" Content="+ Add Parameter"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding AddParamRowCommand}"
                            HorizontalAlignment="Left" Margin="0,4,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="Headers">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding RequestHeaders}"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="On" Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                            <DataGridTextColumn Header="Key" Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Width="*">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="{StaticResource BgInput}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="*">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="{StaticResource BgInput}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="" Width="30">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="x" Style="{StaticResource GhostButton}"
                                                FontSize="10" Padding="2"
                                                Command="{Binding DataContext.RemoveHeaderRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="1" Content="+ Add Header"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding AddHeaderRowCommand}"
                            HorizontalAlignment="Left" Margin="0,4,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="Auth">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel MaxWidth="500">
                        <Label Content="Authorization Type"/>
                        <ComboBox ItemsSource="{Binding AvailableAuthModes}"
                                  SelectedItem="{Binding SelectedAuthMode}"
                                  Margin="0,0,0,12"/>

                        <StackPanel Visibility="{Binding SelectedAuthMode, Converter={StaticResource AuthModeToVisibility}, ConverterParameter=Bearer}">
                            <Label Content="Token"/>
                            <TextBox Text="{Binding AuthToken, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{DynamicResource CodeFont}"/>
                        </StackPanel>

                        <StackPanel Visibility="{Binding SelectedAuthMode, Converter={StaticResource AuthModeToVisibility}, ConverterParameter=Basic}">
                            <Label Content="Username"/>
                            <TextBox Text="{Binding AuthUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>
                            <Label Content="Password"/>
                            <TextBox Text="{Binding AuthPassword, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Visibility="{Binding SelectedAuthMode, Converter={StaticResource AuthModeToVisibility}, ConverterParameter=ApiKey}">
                            <Label Content="Header Name"/>
                            <TextBox Text="{Binding ApiKeyHeader, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>
                            <Label Content="API Key Value"/>
                            <TextBox Text="{Binding ApiKeyValue, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{DynamicResource CodeFont}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Body">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Label Content="Body Type" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding AvailableBodyModes}"
                                  SelectedItem="{Binding SelectedBodyMode}"
                                  MinWidth="130"/>
                    </StackPanel>
                    <avalonedit:TextEditor
                        Grid.Row="1"
                        x:Name="RequestBodyEditor"
                        FontFamily="{DynamicResource CodeFont}"
                        FontSize="{Binding EditorFontSize}"
                        Background="{DynamicResource BgInput}"
                        Foreground="{DynamicResource TextPrimary}"
                        ShowLineNumbers="True"
                        WordWrap="{Binding EditorWordWrap}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        LineNumbersForeground="{DynamicResource TextMuted}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Options">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel MaxWidth="500">
                        <Label Content="Timeout (seconds)"/>
                        <TextBox Text="{Binding RequestTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100"
                                 HorizontalAlignment="Left"
                                 Margin="0,0,0,12"/>

                        <CheckBox Content="Follow redirects"
                                  IsChecked="{Binding RequestFollowRedirects}"
                                  Margin="0,0,0,8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <GridSplitter Grid.Row="2" Height="3"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}"/>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource BgSurface}"
                    Padding="12,8"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                                Visibility="{Binding CurrentResponse, Converter={StaticResource NullToVisibility}}"
                                Background="{Binding CurrentResponse.StatusCode, Converter={StaticResource StatusCodeToBrush}}">
                            <TextBlock FontWeight="Bold" FontSize="12" Foreground="White">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} {1}">
                                        <Binding Path="CurrentResponse.StatusCode"/>
                                        <Binding Path="CurrentResponse.ReasonPhrase"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>

                        <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,12,0"
                                   Visibility="{Binding CurrentResponse, Converter={StaticResource NullToVisibility}}">
                            <TextBlock.Text>
                                <Binding Path="CurrentResponse.Duration.TotalMilliseconds" StringFormat="{}{0:F0} ms"/>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,12,0"
                                   Visibility="{Binding CurrentResponse, Converter={StaticResource NullToVisibility}}"
                                   Text="{Binding CurrentResponse.ResponseSize, Converter={StaticResource FileSizeConverter}}"/>

                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                Visibility="{Binding CurrentResponse, Converter={StaticResource NullToVisibility}}">
                        <Button Content="Download" Style="{StaticResource GhostButton}"
                                Command="{Binding DownloadResponseCommand}" Margin="0,0,4,0"/>
                        <Button Content="Copy Body" Style="{StaticResource GhostButton}"
                                Command="{Binding CopyResponseBodyCommand}" Margin="0,0,4,0"/>
                        <Button Content="Copy Curl" Style="{StaticResource GhostButton}"
                                Command="{Binding CopyAsCurlCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1"
                        SelectedIndex="{Binding SelectedResponseTabIndex}"
                        Background="Transparent">
                <TabItem Header="Pretty">
                    <avalonedit:TextEditor
                        x:Name="ResponsePrettyEditor"
                        FontFamily="{DynamicResource CodeFont}"
                        FontSize="{Binding EditorFontSize}"
                        Background="{DynamicResource BgInput}"
                        Foreground="{DynamicResource TextPrimary}"
                        ShowLineNumbers="True"
                        IsReadOnly="True"
                        WordWrap="{Binding EditorWordWrap}"
                        BorderThickness="0"
                        LineNumbersForeground="{DynamicResource TextMuted}"/>
                </TabItem>

                <TabItem Header="Raw">
                    <TextBox Text="{Binding RawResponseBody, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="{DynamicResource CodeFont}"
                             FontSize="{Binding EditorFontSize}"
                             Background="{DynamicResource BgInput}"
                             BorderThickness="0"
                             Padding="8"/>
                </TabItem>

                <TabItem Header="Headers">
                    <DataGrid ItemsSource="{Binding ResponseHeaders}"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Margin="4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Header" Binding="{Binding Key}" Width="*"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource CodeFont}"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Connection"
                         Visibility="{Binding HasDiagnostics, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12"
                                  DataContext="{Binding ConnectionDiagnostics}">
                        <StackPanel>
                            <Border Margin="0,0,0,16" Padding="12,10" CornerRadius="6"
                                    Background="#2D1418" BorderBrush="#5C2329" BorderThickness="1"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Foreground="#F85149" FontWeight="Bold" FontSize="13">
                                        <Run Text="x "/><Run Text="{Binding FailedPhase, Mode=OneWay}"/><Run Text=" phase failed"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource TextPrimary}"
                                               FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="ENDPOINT" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Host" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" FontFamily="{DynamicResource CodeFont}" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,2" TextWrapping="Wrap">
                                    <Run Text="{Binding Scheme, Mode=OneWay}"/><Run Text="://"/><Run Text="{Binding Host, Mode=OneWay}"/><Run Text=":"/><Run Text="{Binding Port, Mode=OneWay}"/>
                                </TextBlock>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Resolved IPs" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ResolvedIpSummary}" FontFamily="{DynamicResource CodeFont}" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,2" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Connected to" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RemoteEndpoint}" FontFamily="{DynamicResource CodeFont}" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,2"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Local endpoint" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LocalEndpoint}" FontFamily="{DynamicResource CodeFont}" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,2"/>
                            </Grid>

                            <TextBlock Text="TIMING" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding DataContext.TimingPhases, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                                       FontFamily="{DynamicResource CodeFont}" FontSize="11"
                                                       Foreground="{Binding Label, Converter={StaticResource DiagnosticBrush}}"/>
                                            <ProgressBar Grid.Column="1" Style="{StaticResource WaterfallBar}"
                                                         Value="{Binding Milliseconds, Mode=OneWay}"
                                                         Maximum="{Binding ScaleMax, Mode=OneWay}"
                                                         Foreground="{Binding Label, Converter={StaticResource DiagnosticBrush}}"
                                                         VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding MsDisplay}" VerticalAlignment="Center"
                                                       TextAlignment="Right" FontFamily="{DynamicResource CodeFont}"
                                                       FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Margin="0,2,0,18" FontSize="11" Foreground="{DynamicResource TextSecondary}">
                                <Run Text="Total: "/><Run FontFamily="{DynamicResource CodeFont}" Foreground="{DynamicResource TextPrimary}" Text="{Binding Timings.TotalMs, Mode=OneWay, StringFormat={}{0:F0} ms}"/>
                            </TextBlock>

                            <StackPanel Visibility="{Binding IsSecure, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="TLS" Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Protocol" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TlsProtocol}" FontFamily="{DynamicResource CodeFont}" Foreground="{DynamicResource AccentGreen}" FontSize="12" FontWeight="SemiBold" Margin="0,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Cipher suite" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CipherSuite}" FontFamily="{DynamicResource CodeFont}" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,2" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Validation" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SslPolicyErrors}" FontFamily="{DynamicResource CodeFont}" Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,2"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Visibility="{Binding CertificatesPresent, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="CERTIFICATE CHAIN" Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding Certificates}" Margin="0,0,0,18">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <Border Background="{DynamicResource BgInput}" CornerRadius="3" Padding="6,2" Margin="0,0,6,0">
                                                            <TextBlock Text="{Binding Role}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
                                                        </Border>
                                                        <Border CornerRadius="3" Padding="6,2"
                                                                Background="{Binding Status, Converter={StaticResource DiagnosticBrush}}">
                                                            <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Subject}" FontFamily="{DynamicResource CodeFont}" FontSize="12" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                                    <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap">
                                                        <Run Text="Issuer: "/><Run Text="{Binding Issuer, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="{DynamicResource TextSecondary}">
                                                        <Run Text="Valid: "/><Run Text="{Binding NotBefore, Mode=OneWay, StringFormat=yyyy-MM-dd}"/><Run Text=" to "/><Run Text="{Binding NotAfter, Mode=OneWay, StringFormat=yyyy-MM-dd}"/>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap">
                                                        <Run Text="SAN: "/><Run Text="{Binding SansSummary, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="{DynamicResource TextMuted}" FontFamily="{DynamicResource CodeFont}" TextWrapping="Wrap">
                                                        <Run Text="{Binding SignatureAlgorithm, Mode=OneWay}"/><Run Text=" - SN "/><Run Text="{Binding SerialNumber, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <TextBlock Text="RAW REQUEST" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding RawRequest, Mode=OneWay}" IsReadOnly="True"
                                     FontFamily="{DynamicResource CodeFont}" FontSize="12"
                                     Background="{DynamicResource BgInput}" BorderThickness="1"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"
                                     Padding="10" Margin="0,0,0,18"/>

                            <TextBlock Text="RAW RESPONSE HEAD" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding RawResponseHead, Mode=OneWay}" IsReadOnly="True"
                                     FontFamily="{DynamicResource CodeFont}" FontSize="12"
                                     Background="{DynamicResource BgInput}" BorderThickness="1"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"
                                     Padding="10"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.RowSpan="4"
                Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Sending request..."
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="14" HorizontalAlignment="Center"/>
                <Button Content="Cancel" Style="{StaticResource DangerButton}"
                        Command="{Binding CancelCommand}"
                        Margin="0,12,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
