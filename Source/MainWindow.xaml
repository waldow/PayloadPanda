<Window x:Class="PayloadPanda.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PayloadPanda.ViewModels"
        xmlns:models="clr-namespace:PayloadPanda.Models"
        xmlns:views="clr-namespace:PayloadPanda.Views"
        xmlns:helpers="clr-namespace:PayloadPanda.Helpers"
        mc:Ignorable="d"
        Title="PayloadPanda"
        Height="750" Width="1200"
        MinHeight="500" MinWidth="800"
        Background="{DynamicResource BgDeep}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStyle="None"
        Icon="app.ico"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="T" Command="{Binding NewRequestCommand}"/>
        <KeyBinding Modifiers="Control" Key="W" Command="{Binding CloseSelectedTabCommand}"/>
        <KeyBinding Modifiers="Control" Key="Tab" Command="{Binding NextTabCommand}"/>
        <KeyBinding Modifiers="Control+Shift" Key="Tab" Command="{Binding PreviousTabCommand}"/>
    </Window.InputBindings>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="6"
                      CornerRadius="0" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="WindowBorder"
            BorderBrush="{DynamicResource WindowBorderAccent}"
            BorderThickness="1">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource BgSurface}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="16,0,0,0">
                        <Image Source="app.ico" Width="18" Height="18" Margin="0,0,8,0"
                               VerticalAlignment="Center" SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="PayloadPanda" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        <TextBlock Text="v0.5" FontSize="11" Foreground="{DynamicResource TextMuted}"
                                   Margin="8,0,0,2" VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <Button Content="Export" Style="{StaticResource GhostButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Command="{Binding ExportRequestCommand}" Margin="0,0,4,0"/>
                        <Button Content="Import" Style="{StaticResource GhostButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Command="{Binding ImportRequestCommand}" Margin="0,0,4,0"/>
                        <Button Content="Copy Curl" Style="{StaticResource GhostButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Command="{Binding CopyAsCurlCommand}" Margin="0,0,4,0"/>
                        <Button Content="&#x2699;" Style="{StaticResource GhostButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Command="{Binding OpenSettingsCommand}" ToolTip="Settings"
                                FontSize="15" Padding="6,4" Margin="0,0,4,0"/>
                        <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2"/>
                        <Button Content="AI Import" Style="{StaticResource GhostButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Command="{Binding OpenAiImportCommand}" Margin="4,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button x:Name="MinimizeButton" Style="{StaticResource WindowChromeButton}"
                                Click="MinimizeButton_Click" ToolTip="Minimize">
                            <Path Data="M 0 0 H 10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1" Width="10" Height="1"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                        <Button x:Name="MaximizeRestoreButton" Style="{StaticResource WindowChromeButton}"
                                Click="MaximizeRestoreButton_Click" ToolTip="Maximize">
                            <Path x:Name="MaximizeRestoreIcon" Data="M 0 0 H 10 V 10 H 0 Z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1" Width="10" Height="10" Stretch="Uniform"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                        <Button x:Name="CloseButton" Style="{StaticResource WindowChromeCloseButton}"
                                Click="CloseButton_Click" ToolTip="Close">
                            <Path Data="M 0 0 L 10 10 M 0 10 L 10 0"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1" Width="10" Height="10" Stretch="Uniform"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" MinWidth="180"/>
                    <ColumnDefinition Width="3"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource BgSurface}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Border.Resources>
                        <helpers:BindingProxy x:Key="Proxy" Data="{Binding}"/>
                    </Border.Resources>
                    <TabControl SelectedIndex="{Binding LeftPanelTabIndex}"
                                Background="Transparent">
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="SAVED" FontSize="11" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource BgPanel}" CornerRadius="8"
                                            Padding="6,2" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding SavedRequests.Count}" FontSize="10"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </Border>
                                </StackPanel>
                            </TabItem.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Padding="8,6"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Button Content="+ New Request" Style="{StaticResource GhostButton}"
                                            Command="{Binding NewRequestCommand}"
                                            HorizontalAlignment="Stretch" FontSize="11"/>
                                </Border>

                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding SavedRequests}"
                                         SelectedItem="{Binding SelectedSavedRequest}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:SavedRequest}">
                                            <Grid Margin="0,2">
                                                <Grid.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding Data.LoadSavedRequestCommand, Source={StaticResource Proxy}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Grid.InputBindings>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Row="0" Grid.Column="0"
                                                        CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                                        VerticalAlignment="Center"
                                                        Background="{Binding Request.Method, Converter={StaticResource MethodToBrush}}"
                                                        Opacity="0.2">
                                                    <TextBlock Text="{Binding Request.Method}" FontSize="9" FontWeight="Bold"
                                                               Foreground="{Binding Request.Method, Converter={StaticResource MethodToBrush}}"/>
                                                </Border>

                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                           Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                           Text="{Binding Request.Url}" FontSize="10"
                                                           FontFamily="{DynamicResource CodeFont}"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,2,0,0"/>

                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Load"
                                                                  FontWeight="SemiBold"
                                                                  Command="{Binding Data.LoadSavedRequestCommand, Source={StaticResource Proxy}}"
                                                                  CommandParameter="{Binding}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Rename"
                                                                  Command="{Binding Data.RenameSavedRequestCommand, Source={StaticResource Proxy}}"
                                                                  CommandParameter="{Binding}"/>
                                                        <MenuItem Header="Duplicate"
                                                                  Command="{Binding Data.DuplicateSavedRequestCommand, Source={StaticResource Proxy}}"
                                                                  CommandParameter="{Binding}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Delete"
                                                                  Command="{Binding Data.DeleteSavedRequestCommand, Source={StaticResource Proxy}}"
                                                                  CommandParameter="{Binding}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding LoadSavedRequestCommand}"
                                                      CommandParameter="{Binding SelectedSavedRequest}"/>
                                    </ListBox.InputBindings>
                                </ListBox>

                                <Border Grid.Row="2" Padding="8"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                                    <Button Content="Save Current" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding SaveCurrentRequestCommand}"
                                            HorizontalAlignment="Stretch" FontSize="11"/>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="HISTORY" FontSize="11" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource BgPanel}" CornerRadius="8"
                                            Padding="6,2" Margin="6,0,0,0">
                                        <TextBlock Text="{Binding HistoryItems.Count}" FontSize="10"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                    </Border>
                                </StackPanel>
                            </TabItem.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ListBox Grid.Row="0"
                                         ItemsSource="{Binding HistoryItems}"
                                         SelectedItem="{Binding SelectedHistoryItem}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:HistoryItem}">
                                            <Grid Margin="0,2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Row="0" Grid.Column="0"
                                                        CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                                        VerticalAlignment="Center"
                                                        Background="{Binding Method, Converter={StaticResource MethodToBrush}}"
                                                        Opacity="0.2">
                                                    <TextBlock Text="{Binding Method}" FontSize="9" FontWeight="Bold"
                                                               Foreground="{Binding Method, Converter={StaticResource MethodToBrush}}"/>
                                                </Border>

                                                <TextBlock Grid.Row="0" Grid.Column="1"
                                                           Text="{Binding Url}" FontSize="12"
                                                           FontFamily="{DynamicResource CodeFont}"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                           Text="{Binding SavedRequestName}" FontSize="10"
                                                           Foreground="{DynamicResource AccentBlue}"
                                                           Visibility="{Binding SavedRequestName, Converter={StaticResource NullToVisibility}}"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                            Orientation="Horizontal" Margin="0,3,0,0">
                                                    <Border CornerRadius="3" Padding="4,1"
                                                            Background="{Binding StatusCode, Converter={StaticResource StatusCodeToBrush}}"
                                                            Opacity="0.85">
                                                        <TextBlock Text="{Binding StatusCode}" FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <TextBlock FontSize="10" Foreground="{DynamicResource TextMuted}"
                                                               Margin="6,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock.Text>
                                                            <Binding Path="Duration.TotalMilliseconds" StringFormat="{}{0:F0}ms"/>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <TextBlock FontSize="10" Foreground="{DynamicResource TextMuted}"
                                                               Margin="8,0,0,0" VerticalAlignment="Center"
                                                               Text="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding LoadHistoryItemCommand}"
                                                      CommandParameter="{Binding SelectedHistoryItem}"/>
                                    </ListBox.InputBindings>
                                </ListBox>

                                <Border Grid.Row="1" Padding="8"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                                    <Button Content="Clear History" Style="{StaticResource DangerButton}"
                                            Command="{Binding ClearHistoryCommand}"
                                            HorizontalAlignment="Stretch" FontSize="11"/>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>

                <GridSplitter Grid.Column="1" Width="3"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource BorderBrush}"/>

                <Grid Grid.Column="2">
                    <TabControl ItemsSource="{Binding Tabs}"
                                SelectedItem="{Binding SelectedTab}"
                                Background="Transparent">
                        <TabControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:RequestWorkspaceViewModel}">
                                <StackPanel Orientation="Horizontal" MinWidth="120">
                                    <TextBlock Text="{Binding Title}"
                                               MaxWidth="180"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="*" Margin="4,0,0,0"
                                               Foreground="{DynamicResource AccentYellow}"
                                               Visibility="{Binding IsDirty, Converter={StaticResource BoolToVisibility}}"
                                               VerticalAlignment="Center"/>
                                    <Button Content="x"
                                            Style="{StaticResource GhostButton}"
                                            Padding="4,0"
                                            Margin="6,0,0,0"
                                            FontSize="11"
                                            Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Close tab"/>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type vm:RequestWorkspaceViewModel}">
                                <views:RequestWorkspaceView/>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                    <Button Content="+"
                            Style="{StaticResource GhostButton}"
                            Width="28" Height="24"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,4,8,0"
                            Command="{Binding NewRequestCommand}"
                            ToolTip="New tab"/>
                </Grid>
            </Grid>

            <views:AiImportPanel Grid.RowSpan="2"
                                 Visibility="{Binding IsAiImportPanelOpen, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>
    </Border>
</Window>
